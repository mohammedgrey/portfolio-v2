{
  "name": "next-js-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:concurrent",
    "dev:concurrent": "concurrently \"npm run dev:next\" \"npm run dev:type-check\" \"npm run dev:lint\" \"npm run dev:icons\" --prefix-colors \",#3279c6,#4c32c3,#28b8db\" --names \"NEXT,TS,LINT,ICONS\" --kill-others",
    "dev:next": "next dev --turbo",
    "dev:type-check": "npm run type-check:watch",
    "dev:lint": "npm run lint:watch",
    "dev:icons": "npm run update-icons && npm run icons:watch",
    "dev:only": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:run": "eslint src",
    "lint:watch": "chokidar 'src/**/*.{ts,tsx}' -c 'npm run lint:run'",
    "type-check": "tsc --noEmit",
    "type-check:lint-staged": "bash -c 'tsc --noEmit'",
    "type-check:watch": "tsc --noEmit --watch --preserveWatchOutput --pretty",
    "update-icons": "node scripts/update-icons.js",
    "icons:watch": "chokidar \"src/assets/icons/**/*\" -c \"npm run update-icons\"",
    "prepare": "husky",
    "generate:types": "openapi-typescript https://open-data-portal.devclan.io/api-docs/v1/swagger.json --output ./src/api/generated-types.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix",
    "{src,}/**/*.{ts,tsx}": "npm run type-check:lint-staged"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.1",
    "@react-spring/three": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/react-speech-recognition": "^3.9.6",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.560.0",
    "next": "16.0.8",
    "next-intl": "^4.6.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.5",
    "react": "19.2.1",
    "react-cookie": "^8.0.1",
    "react-dom": "19.2.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.69.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-speech-recognition": "^4.0.1",
    "react-textarea-autosize": "^8.5.9",
    "react-virtuoso": "^4.17.0",
    "redux-persist": "^6.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.2.1",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
